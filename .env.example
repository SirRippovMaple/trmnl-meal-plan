# Copy to .env and fill in your values

# Full webhook URL from your TRMNL Webhook Image plugin settings
# (Plugins → Webhook Image → your unique URL)
TRMNL_WEBHOOK_URL=https://usetrmnl.com/api/custom_plugins/your-uuid-here/image

# Times to push each meal (24h HH:MM, evaluated in TIMEZONE)
# Before BREAKFAST_TIME: shows dinner (last meal)
# Between BREAKFAST_TIME and LUNCH_TIME: shows breakfast
# Between LUNCH_TIME and DINNER_TIME: shows lunch
# After DINNER_TIME: shows dinner
BREAKFAST_TIME=07:00
LUNCH_TIME=12:00
DINNER_TIME=18:00

# IANA timezone name
TIMEZONE=America/Indiana/Indianapolis

# Path inside the container — leave as-is (docker-compose mounts ~/notes/keto here)
MEAL_PLAN_DIR=/mealplans
